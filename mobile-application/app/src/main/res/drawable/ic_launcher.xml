<?xml version="1.0" encoding="utf-8"?>
<!--
  Off-Net launcher mark: red squircle, one white node, two arcs leaving it.
  Same glyph as the in-app LogoMark (Primitives.kt) so the brand is a single shape.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Squircle ground. -->
    <path
        android:pathData="M32,0 L76,0 A32,32 0 0 1 108,32 L108,76 A32,32 0 0 1 76,108 L32,108 A32,32 0 0 1 0,76 L0,32 A32,32 0 0 1 32,0 Z"
        android:fillColor="#E8484D" />

    <!-- Node. -->
    <path
        android:pathData="M40,68 m-8,0 a8,8 0 1 0 16,0 a8,8 0 1 0 -16,0"
        android:fillColor="#FFFFFF" />

    <!-- Signal arcs, opening up-right. -->
    <path
        android:pathData="M40,48 A20,20 0 0 1 60,68"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <path
        android:pathData="M40,34 A34,34 0 0 1 74,68"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
</vector>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      BLE runtime permissions (Android 12 / API 31+).
      - BLUETOOTH_SCAN: discover nearby peers advertising our mesh service.
        neverForLocation => we don't derive physical location from BLE, so we
        don't need ACCESS_FINE_LOCATION on 31+ (cleaner permission prompt).
      - BLUETOOTH_ADVERTISE: act as a peripheral (advertise + GATT server).
      - BLUETOOTH_CONNECT: connect as a central and exchange GATT data.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- GPS for the victim's SOS coordinates. Works fully offline (satellites,
         no internet). FINE = precise lat/lng; COARSE as a fallback. -->
    <!-- Voice SOS: recorded on the victim's phone, encoded to Opus, sent as LoRa chunks. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- BLE hardware is required for this app to function at all. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SankatMochan">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SankatMochan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>

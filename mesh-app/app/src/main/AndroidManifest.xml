<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      BLE runtime permissions (Android 12 / API 31+).
      - BLUETOOTH_SCAN: discover nearby peers advertising our mesh service.
        neverForLocation => we don't derive physical location from BLE, so we
        don't need ACCESS_FINE_LOCATION on 31+ (cleaner permission prompt).
      - BLUETOOTH_ADVERTISE: act as a peripheral (advertise + GATT server).
      - BLUETOOTH_CONNECT: connect as a central and exchange GATT data.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- GPS for the victim's SOS coordinates. Works fully offline (satellites,
         no internet). FINE = precise lat/lng; COARSE as a fallback. -->
    <!-- Voice SOS: recorded on the victim's phone, encoded to Opus, sent as LoRa chunks. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notify the victim on their own phone when a responder accepts ("help is on the way").
         Runtime-requested on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Shake-to-SOS (ShakeSosService): a foreground service watches the accelerometer so a hard
      shake can raise the emergency SOS countdown even with the app backgrounded / screen off.
      - FOREGROUND_SERVICE + FOREGROUND_SERVICE_SPECIAL_USE: run the detector as a foreground
        service (API 34+ requires the typed permission; justification in the <service> property).
      - USE_FULL_SCREEN_INTENT: pop the SOS countdown full-screen from the background. On
        Android 14+ a non-calling app may be downgraded to a heads-up notification the user taps.
      SECURITY-SENSITIVE (CLAUDE.md #6): this is user-safety code — reviewer, confirm the shake
      threshold and that no SOS is sent without either the countdown elapsing or an explicit tap.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!--
      SECURITY-SENSITIVE (CLAUDE.md #6): network access.
      The mesh itself never touches the internet — it is BLE/LoRa only. INTERNET is used
      ONLY by the on-device AI assistant to download its LLM weights once from the model
      hub; after that, inference runs fully offline on the Snapdragon NPU. No SOS content,
      location, or mesh traffic is ever sent over the network. Reviewer: confirm no other
      code path performs network I/O.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- BLE hardware is required for this app to function at all. -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.OffNet">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.OffNet"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|density|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shake-to-SOS detector. specialUse: a novel foreground use (emergency shake trigger)
             not covered by a standard FGS type; the subtype string documents why. -->
        <service
            android:name=".ShakeSosService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Emergency shake-to-SOS detection for a disaster-relief safety console" />
        </service>
    </application>
</manifest>
